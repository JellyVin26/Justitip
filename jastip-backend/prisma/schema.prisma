generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  role          String    // BUYER, SELLER
  name          String
  email         String    @unique
  password      String    // Hashed password for auth
  phoneNumber   String?
  avatarUrl     String?
  country           String?
  city              String?
  bio               String?
  preferredCurrency String?   @default("USD")
  trips         Trip[]    // If role is SELLER
  orders        Order[]   // If role is BUYER
  listings      Listing[] // If role is SELLER
  sellerReviews Review[]  @relation("SellerReviews")
  buyerReviews  Review[]  @relation("BuyerReviews")
  followers     Follows[] @relation("following")
  following     Follows[] @relation("follower")
  createdAt     DateTime  @default(now())
}

model Follows {
  followerId  String
  followingId String
  follower    User @relation("follower", fields: [followerId], references: [id])
  following   User @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model Trip {
  id                 String      @id @default(uuid())
  sellerId           String
  seller             User        @relation(fields: [sellerId], references: [id])
  destinationCountry String
  startDate          DateTime
  endDate            DateTime
  markupRules        String      // Stored as JSON string
  notes              String?     // e.g., "Only accepting cosmetics or medicine"
  status             String      @default("UPCOMING")
  orders             Order[]
  listings           Listing[]
  createdAt          DateTime    @default(now())
}

model Listing {
  id              String   @id @default(uuid())
  tripId          String
  trip            Trip     @relation(fields: [tripId], references: [id])
  sellerId        String
  seller          User     @relation(fields: [sellerId], references: [id])
  productName     String
  description     String?
  price           Float    // Base price in local currency
  localCurrency   String   // e.g., "JPY"
  category        String   @default("Other")
  imageUrl        String?
  maxQuantity     Int      @default(0) // 0 means unlimited or unknown
  createdAt       DateTime @default(now())
}

model Order {
  id              String      @id @default(uuid())
  tripId          String
  trip            Trip        @relation(fields: [tripId], references: [id])
  buyerId         String
  buyer           User        @relation(fields: [buyerId], references: [id])
  
  // Product Details
  productName     String
  productLink     String?
  productImageUrl String?
  category        String?
  quantity        Int         @default(1)
  
  // Pricing & Currency
  estimatedPrice  Float?      // In local currency of destination
  originalPrice   Float?      // In local currency of destination
  localCurrency   String      // e.g., "JPY"
  exchangeRate    Float?      // Rate used to convert to IDR
  markupFee       Float?      // In IDR
  shippingFee     Float?      // In IDR
  totalPriceIdr   Float?      // Total in IDR
  
  paymentQrUrl    String?
  status          String      @default("REQUEST_SUBMITTED")
  payments        Payment[]
  messages        Message[]
  history         OrderStatusHistory[]
  review          Review?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  status    String
  createdAt DateTime @default(now())
}

model Payment {
  id            String    @id @default(uuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  amountIdr     Float
  method        String    // e.g., "QRIS"
  qrImageUrl    String?   // URL to the generated QR code
  status        String    // PENDING, SUCCESS, FAILED
  paymentId     String?   // External ID from payment gateway
  createdAt     DateTime  @default(now())
}

model Message {
  id            String    @id @default(uuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  senderId      String
  content       String
  createdAt     DateTime  @default(now())
}

model Review {
  id            String    @id @default(uuid())
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id])
  sellerId      String
  seller        User      @relation("SellerReviews", fields: [sellerId], references: [id])
  buyerId       String
  buyer         User      @relation("BuyerReviews", fields: [buyerId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime  @default(now())
}
